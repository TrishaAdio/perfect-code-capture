# Copy to .env and fill in values.

# ---------- Server ----------
PORT=5000
HOST=0.0.0.0
NODE_ENV=production

# Reverse-proxy hops to trust for req.ip and rate limiting.
# 1 = behind a single proxy (Nginx, Cloudflare). 0 = direct.
TRUST_PROXY=1

# ---------- Database ----------
MONGODB_URI=

# ---------- JWT / sessions ----------
# Long random string (>= 32 chars). Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=2d

# ---------- CORS ----------
# Public URL of the frontend (single origin, no trailing slash).
# Example: CLIENT_URL=https://example.com
CLIENT_URL=

# Optional extra origins, comma-separated (merged with CLIENT_URL).
# Example: CORS_ORIGIN=https://www.example.com,https://app.example.com
CORS_ORIGIN=

# Wildcard is rejected unless explicitly enabled (use only for local debugging).
# In non-production, http://localhost:* is always allowed regardless of this.
CORS_ALLOW_WILDCARD=false


# ---------- Global perimeter whitelist ----------
# Hard block at the edge — non-listed IPs receive a single plaintext line
# ("you are quite funny.") with no JSON, no CORS, no framework headers, and
# the socket is closed. Defaults to disabled unless explicitly enabled.
# WARNING: this blocks ALL public browser traffic too. Set to "false" if the
# frontend needs to call this API from end-user browsers.
GLOBAL_IP_WHITELIST=
GLOBAL_IP_WHITELIST_ENABLED=false

# ---------- Admin / sensitive route protection ----------
# Comma-separated list of IPs allowed to reach /api/admin/*.
# Empty list + ADMIN_IP_WHITELIST_ENABLED=true => denies everything.
ADMIN_IP_WHITELIST=13.236.80.206
# Force on/off. If unset and the list is non-empty, defaults to enabled.
ADMIN_IP_WHITELIST_ENABLED=true

# Optional internal API key for upstream services (NOT required by the admin
# panel — the frontend never carries this key). Comma-separated to support
# rotation. Leave empty unless an external service explicitly needs it.
INTERNAL_API_KEY=

# ---------- Upstream services ----------
# Payment gateway (proxied through /api/payments/*).
PAY_API_URL=
# Order-creation service (proxied through /api/orders).
ORDER_API_URL=
# Transactional email service (proxied through /api/admin/send-email).
EMAIL_API_URL=

# Shared HMAC secret for signing every server-to-server request to the
# PAY/ORDER/EMAIL services. The upstream verifies:
#   X-Symdeals-Timestamp  (UTC seconds, ±300s)
#   X-Symdeals-Nonce      (random 16-byte hex, replay-rejected)
#   X-Symdeals-Signature  hex(HMAC_SHA256(secret, `${ts}.${nonce}.${METHOD}.${path}.${sha256(body)}`))
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Rotate by deploying the new secret to BOTH ends within the 300s replay window,
# then removing the old one. Must be at least 32 chars or signing is disabled.
UPSTREAM_HMAC_SECRET=

# ---------- SMTP / OTP ----------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ---------- Google OAuth ----------
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must EXACTLY match GOOGLE_CALLBACK_URL.
# Example:
#   GOOGLE_CALLBACK_URL=https://api.example.com/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=
